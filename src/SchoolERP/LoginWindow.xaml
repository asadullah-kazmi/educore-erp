<Window x:Class="SchoolERP.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:SchoolERP.Helpers"
        Title="School ERP - Login"
        Height="760"
        Width="1280"
        MinHeight="520"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Background="#E8EEF6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0" />
            <GradientStop Color="#E8EEF6" Offset="0.55" />
            <GradientStop Color="#DCE7F8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#001A3F" Offset="0" />
            <GradientStop Color="#08285D" Offset="0.58" />
            <GradientStop Color="#0E416F" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="SoftTextBrush" Color="#D6E2F2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="InkBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#14C78D" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="13,10" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="White" />
                    <Setter Property="BorderBrush" Value="#2F80ED" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="Padding" Value="10,1,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="#001A3F" />
        </Style>

        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="Padding" Value="10,1,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="#001A3F" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#001A3F" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="12" Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Grid.ColumnSpan="2" />
                                <TextBlock Text="&#xE72A;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="White"
                                           Margin="0,0,18,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Grid.Column="1" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A2C64" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#071C42" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#94A3B8" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#102F61" />
            <Setter Property="BorderBrush" Value="#21477C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}" Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2"
                Background="White"
                CornerRadius="28"
                BorderBrush="#DDE6F2"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="36"
                                  ShadowDepth="0"
                                  Opacity="0.14"
                                  Color="#0B1020" />
            </Border.Effect>
        </Border>

        <Border Margin="10"
                CornerRadius="22"
                Background="{StaticResource BrandGradientBrush}"
                ClipToBounds="True">
            <Grid Margin="46">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <Image Source="pack://application:,,,/Assets/logo.png"
                           Width="74"
                           Height="74"
                           Stretch="Uniform"
                           Margin="0,0,16,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Grammar Public School"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold" />
                        <TextBlock Text="Ghazikot, Mansehra"
                                   Foreground="{StaticResource SoftTextBrush}"
                                   FontSize="14"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="OFFICIAL ERP SYSTEM"
                               Foreground="#8FC7FF"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Run daily school operations from one focused workspace."
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               LineHeight="40"
                               TextWrapping="Wrap"
                               MaxWidth="500"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,16" />
                    <TextBlock Text="Finance, attendance, students, staff, and reports are ready after secure sign in."
                               Foreground="{StaticResource SoftTextBrush}"
                               FontSize="16"
                               LineHeight="23"
                               TextWrapping="Wrap"
                               MaxWidth="460"
                               HorizontalAlignment="Left" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource InsightCardStyle}">
                        <StackPanel>
                            <TextBlock Text="&#xE928;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,10" />
                            <TextBlock Text="Biometric ready"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="Attendance sync support for staff routines."
                                       FontSize="13"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InsightCardStyle}">
                        <StackPanel>
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,10" />
                            <TextBlock Text="Role aware"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="Access opens according to assigned duties."
                                       FontSize="13"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Border MinWidth="320"
                    MaxWidth="430"
                    Background="White"
                    CornerRadius="24"
                    Padding="40"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <Border Background="#EAF0F8"
                            CornerRadius="12"
                            Padding="12,9"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,22">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#001A3F"
                                       FontSize="14"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Authorized access"
                                       Foreground="#001A3F"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Welcome Back"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Sign in to continue to the School ERP dashboard."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,8,0,28"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30"
                                    Height="30"
                                    CornerRadius="10"
                                    Background="#E8F1FB"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE77B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Foreground="#001A3F"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource InputBoxStyle}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30"
                                    Height="30"
                                    CornerRadius="10"
                                    Background="#E8F1FB"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Foreground="#001A3F"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <PasswordBox Grid.Column="1"
                                         Style="{StaticResource PasswordBoxStyle}"
                                         helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <DockPanel Margin="0,0,0,18">
                        <CheckBox Content="Remember me"
                                  Foreground="#334155"
                                  VerticalAlignment="Center"
                                  DockPanel.Dock="Left" />
                        <TextBlock Text="Secure local login"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12.5"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <Button Content="Sign In"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}" />

                    <Border Background="#FEF2F2"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10"
                            Margin="0,16,0,0"
                            MinHeight="42">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#B91C1C"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
