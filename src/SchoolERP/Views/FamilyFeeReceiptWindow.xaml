<Window x:Class="SchoolERP.Views.FamilyFeeReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Family Fee Receipt"
        Width="460"
        SizeToContent="Height"
        MaxHeight="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Arial">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="15">
            <StackPanel x:Name="ReceiptContent">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Image Source="pack://application:,,,/Assets/logo.png" Width="120" Height="120" Stretch="Uniform" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GRAMMAR PUBLIC SCHOOL" FontSize="18" FontWeight="Bold" FontFamily="Arial" TextAlignment="Left" Margin="0,0,0,5"/>
                        <TextBlock Text="GHAZIKOT MANSEHRA" FontSize="16" FontWeight="Bold" FontFamily="Arial" TextAlignment="Left" Margin="0,0,0,10"/>
                        <TextBlock Text="FEE RECEIPT" FontSize="16" FontFamily="Arial" TextAlignment="Left" Foreground="#555"/>
                    </StackPanel>
                </StackPanel>

                <!-- Date line -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Date:" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding PaymentDate, StringFormat='dd MMM yyyy'}" FontSize="14" Margin="5,0,0,0" TextDecorations="Underline"/>
                    </StackPanel>
                </Grid>

                <!-- Table -->
                <Border BorderBrush="Black" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <!-- Table Styles -->
                        <Grid.Resources>
                            <Style TargetType="Border" x:Key="RowBorderStyle">
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                            <Style TargetType="Border" x:Key="ColBorderStyle">
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                            <Style TargetType="TextBlock" x:Key="LabelStyle">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="8,0"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                            <Style TargetType="TextBlock" x:Key="ValueStyle">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="8,0"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </Grid.Resources>

                        <!-- Row 0 -->
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="REG NO" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding AggregatedAdmissionNo}" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 1 -->
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="STUDENTS NAME" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding AggregatedStudentNames}" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 2 -->
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="FATHER NAME" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding AggregatedFatherNames}" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 3 -->
                        <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="CLASS" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding AggregatedClasses}" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 4 -->
                        <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="TOTAL" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding TotalCalculated, StringFormat={}{0:N0}}" Style="{StaticResource ValueStyle}"/>
                        </Border>

                        <!-- Row 5 -->
                        <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="FEE PAID" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding TotalPaid, StringFormat={}{0:N0}}" Style="{StaticResource ValueStyle}"/>
                        </Border>

                        <!-- Row 6 -->
                        <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="BALANCE" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding TotalBalanceAfter, StringFormat={}{0:N0}}" Style="{StaticResource ValueStyle}"/>
                        </Border>

                        <!-- Row 7 (Description) -->
                        <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource ColBorderStyle}">
                            <TextBlock Text="DESCRIPTION" Style="{StaticResource LabelStyle}"/>
                        </Border>
                        <Border Grid.Row="7" Grid.Column="1" Style="{StaticResource RowBorderStyle}">
                            <TextBlock Text="{Binding Description}" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Grid Margin="0,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tel No.: 0997-440050" FontSize="13" FontWeight="Bold" Margin="0,40,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" Width="120" Margin="0,0,0,5"/>
                        <TextBlock Text="ACCOUNTANT" FontWeight="Bold" FontSize="12" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Print" Width="100" Height="35" Margin="0,0,10,0" Background="#001A3F" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Print_Click"/>
            <Button Content="Close" Width="100" Height="35" Background="#F1F5F9" Foreground="#334155" BorderThickness="0" Cursor="Hand" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
