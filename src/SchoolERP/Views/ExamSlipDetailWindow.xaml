<Window x:Class="SchoolERP.Views.ExamSlipDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exam Slip"
        Width="820"
        Height="650"
        MinWidth="500"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Border Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="18"
                Padding="28"
                MinWidth="420">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="GRAMMAR PUBLIC SCHOOL, GHAZIKOT, MANSEHRA"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#001A3F"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TermName, StringFormat='{}{0} Exam Slip'}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#334155"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Exam Number" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding ExamNumber}"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#001A3F"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" MinWidth="140">
                            <TextBlock Text="Generated" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding GeneratedOnDisplay}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                        <TextBlock Text="Student" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding StudentName}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Father" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding FatherName}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Registration No" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding RegistrationNo}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Class" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding ClassName}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Section" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Section}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Print"
                    Click="Print_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,10,0"/>
            <Button Content="Close"
                    Click="Close_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#F1F5F9"
                    Foreground="#334155"/>
        </StackPanel>
    </Grid>
</Window>
