<UserControl x:Class="SchoolERP.Views.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:SchoolERP.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A234F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModuleDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <TextBlock Text="Attendance"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <Button Command="{Binding SyncFingerprintCommand}"
                        IsEnabled="{Binding IsSyncing, Converter={StaticResource InverseBoolToVisibility}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Padding" Value="16,10"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE928;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Sync Fingerprint"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Date navigator row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
            <Button Command="{Binding PreviousDayCommand}"
                    Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="&#xE76B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#0F172A"/>
            </Button>

            <DatePicker Width="160"
                        Height="36"
                        SelectedDate="{Binding SelectedDate}"
                        VerticalContentAlignment="Center"
                        Margin="8,0"/>

            <Button Command="{Binding NextDayCommand}"
                    Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="&#xE76C;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#0F172A"/>
            </Button>

            <TextBlock Text="{Binding SyncStatusMessage}"
                       Foreground="#10B981"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary strip -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- Present Today -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#10B981" Padding="18,14" Margin="0,0,16,0" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Present Today" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PresentTodayCount}" FontSize="20" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Absent Today -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#EF4444" Padding="18,14" Margin="0,0,16,0" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Absent Today" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AbsentTodayCount}" FontSize="20" FontWeight="Bold" Foreground="#EF4444" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Not Marked -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#94A3B8" Padding="18,14" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Not Marked" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding NotMarkedCount}" FontSize="20" FontWeight="Bold" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="AttendanceDataGrid"
                  Grid.Row="3"
                  ItemsSource="{Binding TeacherRows}"
                  Style="{StaticResource ModuleDataGridStyle}"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Designation" Binding="{Binding Designation}" Width="140"/>
                
                <DataGridTemplateColumn Header="Fingerprint ID" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FingerprintID, Converter={StaticResource FingerprintIdConverter}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="In Time" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding InTime, Converter={StaticResource InTimeConverter}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="Status" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="StatusBorder" CornerRadius="6" Padding="6,2" Margin="4" Width="70" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusDisplay}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Present">
                                    <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Absent">
                                    <Setter TargetName="StatusBorder" Property="Background" Value="#EF4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Not Marked">
                                    <Setter TargetName="StatusBorder" Property="Background" Value="#94A3B8"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Mark Present button -->
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.MarkPresentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Mark Present">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#10B981"/>
                                </Button>

                                <!-- Mark Absent button -->
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.MarkAbsentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Mark Absent">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#EF4444"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer TextBlock -->
        <TextBlock Grid.Row="4"
                   Text="{Binding FooterText}"
                   Foreground="#64748B"
                   FontSize="13"
                   Margin="0,12,0,0"/>
    </Grid>
</UserControl>
