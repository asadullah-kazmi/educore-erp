<Window x:Class="SchoolERP.Views.FeeReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fee Receipt"
        Width="440"
        SizeToContent="Height"
        MaxHeight="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ReceiptLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ReceiptValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Margin="16"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ReceiptContent">
                    <TextBlock Text="GRAMMAR PUBLIC SCHOOL, GHAZIKOT, MANSEHRA"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#001A3F"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Fee Payment Receipt"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               TextAlignment="Center"
                               Margin="0,0,0,18"/>

                    <Border Height="3"
                            CornerRadius="2"
                            Background="#001A3F"
                            Width="56"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Receipt No" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding ReceiptNumber}" Style="{StaticResource ReceiptValueStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Date" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding ReceiptDate, StringFormat='dd MMM yyyy'}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Student Name" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding StudentName}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Registration No" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding RegistrationNo}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Class" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding ClassName}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Section" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding Section}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Amount Paid" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding PaidAmount, StringFormat='Rs {0:N0}'}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Payment Details" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding Details}" Style="{StaticResource ReceiptValueStyle}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Remaining Balance" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="{Binding Balance, StringFormat='Rs {0:N0}'}" Style="{StaticResource ReceiptValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="5" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Status" Style="{StaticResource ReceiptLabelStyle}"/>
                            <TextBlock Text="Received" FontSize="14" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Thank you for your payment."
                               FontSize="12"
                               Foreground="#64748B"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Print"
                        Width="100"
                        Height="38"
                        Margin="0,0,10,0"
                        Background="#001A3F"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="PrintButton_Click"/>
                <Button Content="Close"
                        Width="100"
                        Height="38"
                        Background="#F1F5F9"
                        Foreground="#334155"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
