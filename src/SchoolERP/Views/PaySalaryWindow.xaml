<Window x:Class="SchoolERP.Views.PaySalaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding TeacherName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="{Binding Designation}" Foreground="#64748B" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Base Salary: Rs "/>
            <TextBlock Text="{Binding BaseSalaryDisplay}" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Payment Amount" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" Height="38" Padding="10,8"/>
            <TextBlock Text="{Binding AmountError}" Foreground="#DC2626" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Payment Date" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DatePicker SelectedDate="{Binding PaymentDate}" Height="38"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="72" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Width="100" Height="36" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Save" Width="100" Height="36" Background="#001A3F" Foreground="White"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>
