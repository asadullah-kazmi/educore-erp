<UserControl x:Class="SchoolERP.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BorderBrush" Value="#E5EAF2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Width" Value="248" />
            <Setter Property="MinHeight" Value="128" />
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="17" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="BorderBrush" Value="#E5EAF2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SmallLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="IconTileStyle" TargetType="Border">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#001A3F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A2C64" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#071C42" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Width" Value="142" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCustomPeriod}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCustomPeriod}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,8,0">
            <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center"
                                Margin="0,0,28,0">
                        <TextBlock Text="Dashboard"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="{Binding DateRangeLabel}"
                                   Foreground="#64748B"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <ComboBox Width="188"
                                  Height="36"
                                  ItemsSource="{Binding PeriodOptions}"
                                  SelectedItem="{Binding SelectedPeriod}"
                                  Margin="0,0,12,8" />

                        <DatePicker SelectedDate="{Binding CustomFromDate}"
                                    Style="{StaticResource CustomDatePickerStyle}" />

                        <DatePicker SelectedDate="{Binding CustomToDate}"
                                    Style="{StaticResource CustomDatePickerStyle}"
                                    Margin="0,0,12,8" />

                        <Button Content="Apply"
                                Command="{Binding ApplyCustomRangeCommand}"
                                Style="{StaticResource ApplyButtonStyle}" />

                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource FilterButtonStyle}"
                                Background="#0F766E"
                                Margin="0,0,0,8" />
                    </WrapPanel>
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#B91C1C"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="4,0,0,10" />

            <WrapPanel>
                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource IconTileStyle}" Background="#E8F1FB">
                            <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Total Students" Style="{StaticResource SmallLabelStyle}" />
                            <TextBlock Text="{Binding TotalStudents}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="{Binding NewAdmissions, StringFormat='+{0} admissions in period'}" Style="{StaticResource SmallLabelStyle}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource IconTileStyle}" Background="#ECFDF5">
                            <TextBlock Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Total Teachers" Style="{StaticResource SmallLabelStyle}" />
                            <TextBlock Text="{Binding TotalTeachers}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Staff capacity" Style="{StaticResource SmallLabelStyle}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource IconTileStyle}" Background="#F0F9FF">
                            <TextBlock Text="&#xEAFD;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#0284C7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding FeesCollectedLabel}" Style="{StaticResource SmallLabelStyle}" />
                            <TextBlock Text="{Binding FeesPaidThisMonth, StringFormat='Rs {0:N0}'}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="{Binding AverageDailyCollection, StringFormat='Avg Rs {0:N0} / day'}" Style="{StaticResource SmallLabelStyle}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource IconTileStyle}" Background="#FEF2F2">
                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fees Outstanding" Style="{StaticResource SmallLabelStyle}" />
                            <TextBlock Text="{Binding FeesDueThisMonth, StringFormat='Rs {0:N0}'}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="{Binding CollectionRate, StringFormat='Collection rate {0:P0}'}" Style="{StaticResource SmallLabelStyle}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </WrapPanel>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Finance Control"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="Selected period"
                                       Grid.Column="1"
                                       Foreground="#64748B"
                                       Margin="20,4,0,0" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="16" MinHeight="112">
                                <StackPanel>
                                    <TextBlock Text="Expenses" Style="{StaticResource SmallLabelStyle}" />
                                    <TextBlock Text="{Binding TotalExpenses, StringFormat='Rs {0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="14" Padding="16" MinHeight="112">
                                <StackPanel>
                                    <TextBlock Text="Salaries Paid" Style="{StaticResource SmallLabelStyle}" />
                                    <TextBlock Text="{Binding SalariesPaid, StringFormat='Rs {0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="#ECFDF5" CornerRadius="14" Padding="16" MinHeight="112">
                                <StackPanel>
                                    <TextBlock Text="Net Balance" Style="{StaticResource SmallLabelStyle}" />
                                    <TextBlock Text="{Binding NetBalance, StringFormat='Rs {0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#047857" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="Collection progress"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,18,0,8" />
                        <ProgressBar Height="10"
                                     Maximum="1"
                                     Value="{Binding CollectionRate}"
                                     Foreground="#0F766E"
                                     Background="#E2E8F0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Staff Attendance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="{Binding AttendanceMarkedCount, StringFormat='{}{0} marks'}"
                                       Grid.Column="1"
                                       Foreground="#64748B"
                                       Margin="20,4,0,0" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="#ECFDF5" CornerRadius="14" Padding="16" MinHeight="128">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Present" Style="{StaticResource SmallLabelStyle}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding PresentTodayCount}" FontSize="34" FontWeight="Bold" Foreground="#047857" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#FEF2F2" CornerRadius="14" Padding="16" MinHeight="128">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Absent" Style="{StaticResource SmallLabelStyle}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding AbsentTodayCount}" FontSize="34" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding AttendanceRate, StringFormat='Presence rate {0:P0}'}"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,18,0,8" />
                        <ProgressBar Height="10"
                                     Maximum="1"
                                     Value="{Binding AttendanceRate}"
                                     Foreground="#2563EB"
                                     Background="#E2E8F0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource PanelStyle}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Operational Snapshot"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="Use the period controls above to compare today, recent activity, monthly results, or a custom period."
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,6,20,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Admissions in Period" Style="{StaticResource SmallLabelStyle}" />
                        <TextBlock Text="{Binding NewAdmissions}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="20,0,0,0">
                        <TextBlock Text="Average Collection" Style="{StaticResource SmallLabelStyle}" />
                        <TextBlock Text="{Binding AverageDailyCollection, StringFormat='Rs {0:N0}/day'}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
