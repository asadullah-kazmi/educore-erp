<Window x:Class="SchoolERP.Views.StaffDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Staff Details"
        Height="620"
        Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style x:Key="DocumentPreviewStyle" TargetType="Image">
            <Setter Property="Height" Value="130"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#001A3F"
                    CornerRadius="20,20,0,0"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Designation}"
                               FontSize="14"
                               Foreground="#D6E2F2"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="24,24,24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Teacher ID" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding TeacherID}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Designation" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding Designation}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Base Salary" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding SalaryDisplay}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Fingerprint ID" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding FingerprintId, TargetNullValue='Not Assigned'}"
                                       Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="DOB" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding DOBDisplay}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Age" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding Age, TargetNullValue='-'}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Contact Number" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding ContactNumber, TargetNullValue='-'}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Date of Joining" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding DateOfJoiningDisplay}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Experience" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding Experience, TargetNullValue='-'}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CNIC Number" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding CnicNumber, TargetNullValue='-'}" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Address" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{Binding Address, TargetNullValue='-'}" TextWrapping="Wrap" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CNIC Front Image" Style="{StaticResource CardLabelStyle}"/>
                            <Image Source="{Binding CnicFrontImage}" Style="{StaticResource DocumentPreviewStyle}" Visibility="{Binding HasCnicFrontImage, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding CnicFrontStoredLabel}" TextWrapping="Wrap" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CNIC Back Image" Style="{StaticResource CardLabelStyle}"/>
                            <Image Source="{Binding CnicBackImage}" Style="{StaticResource DocumentPreviewStyle}" Visibility="{Binding HasCnicBackImage, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding CnicBackStoredLabel}" TextWrapping="Wrap" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Educational Documents" Style="{StaticResource CardLabelStyle}"/>
                            <Image Source="{Binding EducationalDocumentImage}" Style="{StaticResource DocumentPreviewStyle}" Visibility="{Binding HasEducationalDocumentImage, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding EducationalDocumentStoredLabel}" TextWrapping="Wrap" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="7" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Certificates" Style="{StaticResource CardLabelStyle}"/>
                            <Image Source="{Binding CertificateImage}" Style="{StaticResource DocumentPreviewStyle}" Visibility="{Binding HasCertificateImage, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding CertificateStoredLabel}" TextWrapping="Wrap" Style="{StaticResource CardValueStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Content="Close"
                    Width="100"
                    Height="38"
                    HorizontalAlignment="Right"
                    Margin="24,16,24,20"
                    Background="#001A3F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
