<Window x:Class="SchoolERP.Views.RecordFeePaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Fee Payment"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="18"
            Margin="16"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Record Fee Payment"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>
                <TextBlock x:Name="TxtStudent"
                           Foreground="#64748B"
                           FontSize="13"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Total Payable" Foreground="#64748B" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="TxtTotalPayable" Foreground="#EF4444" FontWeight="Bold" FontSize="22" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Payment Type" Foreground="#64748B" FontWeight="SemiBold" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <RadioButton x:Name="RadioFull"
                                         Content="Full"
                                         IsChecked="True"
                                         Margin="0,0,18,0"
                                         Checked="PaymentType_Checked"/>
                            <RadioButton x:Name="RadioPartial"
                                         Content="Partial"
                                         Checked="PaymentType_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Payment Date" Foreground="#64748B" FontWeight="SemiBold" FontSize="12"/>
                        <DatePicker x:Name="DpPaymentDate" Height="34" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <DataGrid Grid.Row="2"
                      x:Name="FeeGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      BorderBrush="#E2E8F0"
                      BorderThickness="1"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="95" ElementStyle="{StaticResource GridCellTextStyle}"/>
                    <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeType}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N0}}" Width="95" ElementStyle="{StaticResource GridCellTextStyle}"/>
                    <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:N0}}" Width="95" ElementStyle="{StaticResource GridCellTextStyle}"/>
                    <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat={}{0:N0}}" Width="95" ElementStyle="{StaticResource GridCellTextStyle}"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" ElementStyle="{StaticResource GridCellTextStyle}"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                <TextBlock Text="Amount Received" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="TxtPaymentAmount"
                         Style="{StaticResource FieldInputStyle}"
                         Width="180"
                         HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Cancel"
                        Width="90"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"
                        Background="#F1F5F9"
                        Foreground="#334155"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="Save Payment"
                        Width="120"
                        Height="36"
                        Click="Save_Click"
                        Background="#001A3F"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
