<UserControl x:Class="SchoolERP.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SchoolERP.Helpers"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A234F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModuleDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <!-- TAB 1 — Expenses -->
            <TabItem Header="Expenses">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action Bar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
                        <TextBlock Text="Expenses"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        
                        <Button Content="Add Expense"
                                Command="{Binding AddExpenseCommand}"
                                Padding="16,10"
                                Margin="8,0,0,0"
                                Background="#22C55E"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="13"
                                BorderThickness="0"
                                Cursor="Hand"
                                DockPanel.Dock="Right"
                                FlowDirection="LeftToRight">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </DockPanel>

                    <!-- Summary Strip -->
                    <Border Grid.Row="1"
                            Background="White"
                            CornerRadius="12"
                            BorderThickness="4,1,1,1"
                            BorderBrush="#10B981"
                            Padding="18,14"
                            Width="320"
                            Height="82"
                            Margin="0,0,0,12">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ExpenseMonthFilter, StringFormat='Total Expenses ({0})'}"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalExpensesFiltered, StringFormat='Rs {0:N0}'}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#10B981"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Filter Bar -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="260"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,6"
                                Margin="0,0,12,0">
                            <DockPanel>
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBox Text="{Binding ExpenseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         Foreground="#0F172A"
                                         FontSize="14"/>
                            </DockPanel>
                        </Border>

                        <ComboBox Width="160"
                                  Height="36"
                                  ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding ExpenseCategoryFilter}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,12,0"/>

                        <ComboBox Width="120"
                                  Height="36"
                                  ItemsSource="{Binding SummaryMonthOptions}"
                                  SelectedItem="{Binding ExpenseMonthFilter}"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding FilteredExpenses}"
                              Style="{StaticResource ModuleDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="110">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            <DataGridTemplateColumn Header="Actions" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding DataContext.EditExpenseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Edit">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#3B82F6"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding DataContext.DeleteExpenseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete"
                                                    Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#DC2626"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 2 — Salaries -->
            <TabItem Header="Salaries">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Action Bar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
                        <TextBlock Text="Salaries"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>

                        <ComboBox Width="130"
                                  Height="36"
                                  ItemsSource="{Binding SalaryMonthOptions}"
                                  SelectedItem="{Binding SalaryMonthFilter}"
                                  VerticalContentAlignment="Center"
                                  DockPanel.Dock="Right"/>
                    </DockPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding StaffRows}"
                              Style="{StaticResource ModuleDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Designation" Binding="{Binding Designation}" Width="*"/>
                            <DataGridTextColumn Header="Base Salary" Binding="{Binding BaseSalaryDisplay}" Width="120">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Status" Width="95">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="StatusBorder" CornerRadius="6" Padding="6,2" Margin="4" Width="70" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding PaidStatusLabel}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding PaidThisMonth}" Value="True">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaidThisMonth}" Value="False">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#FF6B35"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Last Paid" Binding="{Binding LastPaymentDateDisplay}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Pay"
                                                    Command="{Binding DataContext.PaySalaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="50"
                                                    Height="28"
                                                    Padding="0"
                                                    Background="#22C55E"
                                                    Foreground="White"
                                                    FontWeight="SemiBold"
                                                    FontSize="12"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Margin="0,0,4,0"
                                                    Visibility="{Binding PaidThisMonth, Converter={StaticResource InverseBoolToVisibility}}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding DataContext.ViewHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="View History">
                                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#3B82F6"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Summary Strip -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,12,0,0">
                        <TextBlock Text="{Binding TotalSalaryPaidThisMonth, StringFormat='Total Paid This Month: Rs {0:N0}'}"
                                   Foreground="#10B981"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding PendingCount, StringFormat='  |  Pending: {0} teachers'}"
                                   Foreground="#FF6B35"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3 — Summary -->
            <TabItem Header="Summary" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,4,8,4">
                    <StackPanel>

                        <!-- Month Picker Row -->
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="Monthly Summary"
                                       FontSize="22" FontWeight="Bold" Foreground="#0F172A"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <ComboBox Width="140" Height="36"
                                      ItemsSource="{Binding SummaryMonthOptions}"
                                      SelectedItem="{Binding SelectedSummaryMonth}"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Right"
                                      DockPanel.Dock="Right"/>
                        </DockPanel>

                        <!-- KPI Cards 2x2 Grid -->
                        <UniformGrid Columns="2" Margin="0,0,0,20">

                            <!-- Card 1: Fees Collected -->
                            <Border Background="White" CornerRadius="18" Padding="18"
                                    Margin="0,0,12,12" Height="110"
                                    BorderBrush="#10B981" BorderThickness="4,1,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="46" Height="46" CornerRadius="14"
                                            Background="#ECFDF5" VerticalAlignment="Center">
                                        <TextBlock Text="&#xEAFD;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="22" Foreground="#10B981"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Fees Collected" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding CurrentSummary.TotalFeesCollected, StringFormat='Rs {0:N0}', FallbackValue='Rs 0'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 2: Total Expenses -->
                            <Border Background="White" CornerRadius="18" Padding="18"
                                    Margin="0,0,0,12" Height="110"
                                    BorderBrush="#EF4444" BorderThickness="4,1,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="46" Height="46" CornerRadius="14"
                                            Background="#FEF2F2" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="22" Foreground="#EF4444"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Total Expenses" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding CurrentSummary.TotalExpenses, StringFormat='Rs {0:N0}', FallbackValue='Rs 0'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 3: Salaries Paid -->
                            <Border Background="White" CornerRadius="18" Padding="18"
                                    Margin="0,0,12,0" Height="110"
                                    BorderBrush="#3B82F6" BorderThickness="4,1,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="46" Height="46" CornerRadius="14"
                                            Background="#EFF6FF" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="22" Foreground="#3B82F6"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Salaries Paid" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding CurrentSummary.TotalSalariesPaid, StringFormat='Rs {0:N0}', FallbackValue='Rs 0'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 4: Net Surplus (dynamic color) -->
                            <Border Background="White" CornerRadius="18" Padding="18"
                                    Margin="0,0,0,0" Height="110"
                                    BorderBrush="{Binding SurplusColor}" BorderThickness="4,1,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="46" Height="46" CornerRadius="14"
                                            Background="#F0FDF4" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="22" Foreground="{Binding SurplusColor}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Net Surplus" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding CurrentSummary.NetSurplus, StringFormat='Rs {0:N0}', FallbackValue='Rs 0'}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding SurplusColor}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </UniformGrid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <TextBlock Text="Reports &amp; Export"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,14"/>

                        <WrapPanel Orientation="Horizontal">

                            <Border Margin="0,0,12,0" CornerRadius="12"
                                    Background="#001A3F" Cursor="Hand">
                                <Button Command="{Binding PrintFeeReportCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="20,12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Print Fee Report"
                                                   Foreground="White" FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border Margin="0,0,12,0" CornerRadius="12"
                                    Background="#0F172A" Cursor="Hand">
                                <Button Command="{Binding PrintExpenseReportCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="20,12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Print Expense Report"
                                                   Foreground="White" FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border CornerRadius="12"
                                    Background="#6366F1" Cursor="Hand">
                                <Button Command="{Binding ExportSummaryCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="20,12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Export CSV"
                                                   Foreground="White" FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>

                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
