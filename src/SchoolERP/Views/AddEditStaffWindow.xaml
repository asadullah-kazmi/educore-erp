<Window x:Class="SchoolERP.Views.AddEditStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="760"
        SizeToContent="Height"
        MaxHeight="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FieldComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Padding="0"
            Margin="16">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,22"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,18,0">
                <StackPanel Margin="0,0,16,4">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="Full Name *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding NameError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Staff Type *" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding StaffTypeOptions}"
                                      Text="{Binding StaffType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Style="{StaticResource FieldComboStyle}"/>
                            <TextBlock Text="{Binding StaffTypeError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Designation *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Designation, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding DesignationError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="DOB *" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DOB}" Height="38"/>
                            <TextBlock Text="{Binding DOBError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Age" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding AgeText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding AgeError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="Contact Number *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding ContactNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding ContactNumberError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Date of Joining *" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DateOfJoining}" Height="38"/>
                            <TextBlock Text="{Binding DateOfJoiningError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="Base Salary *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding SalaryText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding SalaryError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Experience" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Experience, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="CNIC Number *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding CnicNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding CnicNumberError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="Fingerprint ID" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FingerprintIdText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                            <TextBlock Text="{Binding FingerprintIdError}" Style="{StaticResource ErrorTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,18">
                            <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     Height="70"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource FieldInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="7" Grid.Column="0" Margin="0,0,0,18">
                            <TextBlock Text="CNIC Image Front" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel>
                                <Button Content="Browse" Width="86" Height="38" Command="{Binding BrowseCnicFrontCommand}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding CnicFrontImagePath}" IsReadOnly="True" Style="{StaticResource FieldInputStyle}"/>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="7" Grid.Column="2" Margin="0,0,0,18">
                            <TextBlock Text="CNIC Image Back" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel>
                                <Button Content="Browse" Width="86" Height="38" Command="{Binding BrowseCnicBackCommand}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding CnicBackImagePath}" IsReadOnly="True" Style="{StaticResource FieldInputStyle}"/>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Grid.Column="0" Margin="0,0,0,2">
                            <TextBlock Text="Educational Documents" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel>
                                <Button Content="Browse" Width="86" Height="38" Command="{Binding BrowseEducationalDocumentsCommand}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding EducationalDocumentsPath}" IsReadOnly="True" Style="{StaticResource FieldInputStyle}"/>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Grid.Column="2" Margin="0,0,0,2">
                            <TextBlock Text="Certificates" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel>
                                <Button Content="Browse" Width="86" Height="38" Command="{Binding BrowseCertificatesCommand}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding CertificatesPath}" IsReadOnly="True" Style="{StaticResource FieldInputStyle}"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,18,0">
                <Button Content="Cancel"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding CancelCommand}"
                        Background="#F1F5F9"
                        Foreground="#334155"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="Save"
                        Width="100"
                        Height="40"
                        Command="{Binding SaveCommand}"
                        Background="#001A3F"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
