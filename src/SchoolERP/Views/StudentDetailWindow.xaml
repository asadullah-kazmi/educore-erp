<Window x:Class="SchoolERP.Views.StudentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Details"
        Height="720"
        Width="900"
        MinHeight="560"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ImageDownloadButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#001A3F"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Student.Name}"
                               FontSize="23"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Student.RegistrationNo}"
                               FontSize="14"
                               Foreground="#D6E2F2"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#123567"
                        CornerRadius="14"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Student.ClassName}"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="18">
            <StackPanel>
                <Border Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Father Name" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.FatherName}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Date of Birth" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.DOB, StringFormat='dd MMM yyyy'}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.Phone}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="Monthly Fee" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.MonthlyFee, StringFormat='Rs {0:N0}'}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Admission Date" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.AdmissionDateDisplay}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Class" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.ClassName}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="Section" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.Section}" Style="{StaticResource FieldValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.Address}" Style="{StaticResource FieldValueStyle}" Margin="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Student Identity"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Form-B / CNIC Number" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.StudentFormBOrCnicNumber}" Style="{StaticResource FieldValueStyle}"/>
                            <TextBlock Text="Form-B / CNIC Front Picture" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E5EAF2"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,4,0,8">
                                <Image Source="{Binding Student.StudentFormBOrCnicFrontImage}"
                                       MaxHeight="150"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"/>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Student.StudentFormBOrCnicFrontStoredLabel}"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Download"
                                        Command="{Binding DownloadImageCommand}"
                                        CommandParameter="StudentFront"
                                        Style="{StaticResource ImageDownloadButtonStyle}"/>
                            </Grid>
                            <TextBlock Text="Form-B / CNIC Back Picture" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E5EAF2"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,4,0,8">
                                <Image Source="{Binding Student.StudentFormBOrCnicBackImage}"
                                       MaxHeight="150"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"/>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Student.StudentFormBOrCnicBackStoredLabel}"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Download"
                                        Command="{Binding DownloadImageCommand}"
                                        CommandParameter="StudentBack"
                                        Style="{StaticResource ImageDownloadButtonStyle}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Guardian &amp; Emergency"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Guardian CNIC Number" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.GuardianCnicNumber}" Style="{StaticResource FieldValueStyle}"/>
                            <TextBlock Text="Guardian Phone Number" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.GuardianPhone}" Style="{StaticResource FieldValueStyle}"/>
                            <TextBlock Text="Emergency Contact Number" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Student.EmergencyContactNumber}" Style="{StaticResource FieldValueStyle}"/>
                            <TextBlock Text="Guardian CNIC Front Picture" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E5EAF2"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,4,0,8">
                                <Image Source="{Binding Student.GuardianCnicFrontImage}"
                                       MaxHeight="150"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"/>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Student.GuardianCnicFrontStoredLabel}"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Download"
                                        Command="{Binding DownloadImageCommand}"
                                        CommandParameter="GuardianFront"
                                        Style="{StaticResource ImageDownloadButtonStyle}"/>
                            </Grid>
                            <TextBlock Text="Guardian CNIC Back Picture" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E5EAF2"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,4,0,8">
                                <Image Source="{Binding Student.GuardianCnicBackImage}"
                                       MaxHeight="150"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"/>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Student.GuardianCnicBackStoredLabel}"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Download"
                                        Command="{Binding DownloadImageCommand}"
                                        CommandParameter="GuardianBack"
                                        Style="{StaticResource ImageDownloadButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Fee History"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,12"/>

                        <DataGrid ItemsSource="{Binding FeeHistory}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#E2E8F0"
                                  BorderBrush="#E2E8F0"
                                  BorderThickness="1"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC"
                                  Background="White"
                                  RowHeight="38"
                                  ColumnHeaderHeight="36"
                                  MaxHeight="220"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="100"/>
                                <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeType}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='Rs {0:N0}'}" Width="110"/>
                                <DataGridTemplateColumn Header="Status" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="StatusBorder" CornerRadius="6" Padding="6,2" Margin="4" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="11"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Due">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#FF6B35"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDate, StringFormat='dd MMM yyyy'}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="#64748B"
                                   FontSize="13"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5EAF2"
                BorderThickness="0,1,0,0"
                Padding="18,12">
            <Button Content="Close"
                    Width="100"
                    Height="38"
                    HorizontalAlignment="Right"
                    Background="#001A3F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</Window>
