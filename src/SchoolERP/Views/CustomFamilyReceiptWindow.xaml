<Window x:Class="SchoolERP.Views.CustomFamilyReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Family Fee Payment" Width="1020" Height="720" MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="#EEF2F7" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Search bar -->
            <RowDefinition Height="Auto"/>  <!-- Payment input -->
            <RowDefinition Height="*"/>     <!-- Siblings grid -->
            <RowDefinition Height="Auto"/>  <!-- Summary bar -->
            <RowDefinition Height="Auto"/>  <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Family Fee Payment" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Enter guardian CNIC to find siblings, then enter total payment amount. Amount is distributed youngest class first." Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- SEARCH BAR -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Guardian CNIC" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="GuardianCnicTextBox" Height="40" Padding="12,0" VerticalContentAlignment="Center" FontSize="14"/>
            </StackPanel>
            <Button Grid.Column="1" Content="🔍  Find Siblings" Click="FindSiblings_Click" Style="{StaticResource ActionButton}" Margin="0,22,14,0"/>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Payment Date" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="PaymentDatePicker" Height="40"/>
            </StackPanel>
        </Grid>

        <!-- PAYMENT AMOUNT INPUT -->
        <Border Grid.Row="2" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Padding="16" Margin="0,0,0,14" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Total Payment Amount (Rs)" FontWeight="Bold" Foreground="#0F172A" FontSize="15" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBox Grid.Column="1" x:Name="PaymentAmountTextBox" Height="44" Padding="12,0"
                         VerticalContentAlignment="Center" FontSize="18" FontWeight="Bold"
                         Foreground="#047857" Background="#F0FDF4" BorderBrush="#86EFAC"
                         TextChanged="PaymentAmountTextBox_TextChanged"/>
                <TextBlock Grid.Column="2" x:Name="DistributionHintText" Foreground="#64748B" VerticalAlignment="Center"
                           Margin="16,0,0,0" TextWrapping="Wrap" FontSize="12"/>
            </Grid>
        </Border>

        <!-- SIBLINGS GRID -->
        <DataGrid Grid.Row="3" x:Name="SiblingGrid" ItemsSource="{Binding Siblings}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" SelectionMode="Single"
                  HeadersVisibility="Column" RowHeight="48" ColumnHeaderHeight="42"
                  BorderBrush="#CBD5E1" HorizontalGridLinesBrush="#E2E8F0"
                  VerticalGridLinesBrush="Transparent"
                  RowBackground="White" AlternatingRowBackground="#F8FAFC"
                  GridLinesVisibility="Horizontal">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="Foreground" Value="#334155"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="12,0"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*" MinWidth="140"/>
                <DataGridTextColumn Header="Reg No" Binding="{Binding RegistrationNo}" Width="110"/>
                <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="90"/>
                <DataGridTextColumn Header="Monthly Fee" Binding="{Binding MonthlyFee, StringFormat='Rs {0:N0}'}" Width="110"/>
                <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingBalance, StringFormat='Rs {0:N0}'}" Width="115"/>
                <DataGridTextColumn Header="Allocated" Binding="{Binding AllocatedAmount, StringFormat='Rs {0:N0}'}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#047857"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Pending" Binding="{Binding PendingAmount, StringFormat='Rs {0:N0}'}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                    <Setter Property="Foreground" Value="#D97706"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Paid">
                                    <Setter Property="Foreground" Value="#047857"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Status" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FEE2E2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Paid">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="No Dues">
                                                <Setter Property="Background" Value="#E0F2FE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PaymentStatus}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Paid">
                                                    <Setter Property="Foreground" Value="#047857"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="No Dues">
                                                    <Setter Property="Foreground" Value="#0369A1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- SUMMARY BAR -->
        <Border Grid.Row="4" Background="White" BorderBrush="#10B981" BorderThickness="4,1,1,1" Padding="18" Margin="0,16,0,0" CornerRadius="0,6,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Siblings Found" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="SiblingCountText" Text="0" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Total Outstanding" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="TotalOutstandingText" Text="Rs 0" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Total Allocated" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="TotalAllocatedText" Text="Rs 0" FontSize="22" FontWeight="Bold" Foreground="#047857"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Total Pending" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="TotalPendingText" Text="Rs 0" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ACTION BAR -->
        <DockPanel Grid.Row="5" Margin="0,18,0,0">
            <TextBlock x:Name="StatusText" Foreground="#DC2626" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="500"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="💳  Pay &amp; Generate Receipt" Click="GenerateReceipt_Click"
                        Style="{StaticResource ActionButton}" Background="#22C55E" Margin="0,0,10,0" FontSize="14"/>
                <Button Content="Close" Click="Close_Click"
                        Style="{StaticResource ActionButton}" Background="#64748B"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
